# Slack Configuration
# NOTE: Slack requires HTTPS for redirect URIs. For local dev, use ngrok or similar tunneling service
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_REDIRECT_URI=https://your-ngrok-url.ngrok.io/api/auth/slack/callback

# Microsoft Configuration (for Outlook & Teams)
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_REDIRECT_URI=https://your-ngrok-url.ngrok.io/api/auth/microsoft/callback

# Claude API (Optional, for AI features)
CLAUDE_API_KEY=your_claude_api_key

# Application
# Use your ngrok URL for local development, or your production domain
NEXT_PUBLIC_APP_URL=https://your-ngrok-url.ngrok.io
SESSION_SECRET=your_session_secret_key_here

# Database (for future use)
DATABASE_URL=postgresql://user:password@localhost:5432/oneui
